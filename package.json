{
  "name": "linkedin-pages-mcp",
  "mcpName": "io.github.lanternrow/linkedin-pages-mcp",
  "version": "1.0.0",
  "description": "MCP server for LinkedIn organization (Company Page) analytics via the Community Management API — follower, page, post/share, and video statistics. Read-only, aggregate Page data only. Built for Claude Code and other MCP-compatible AI tools.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "linkedin-pages-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "release": "node release.mjs",
    "release:registry": "mcp-publisher publish"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "linkedin",
    "linkedin-analytics",
    "company-page",
    "social-media",
    "community-management-api",
    "claude",
    "claude-code",
    "ai-tools"
  ],
  "author": "The SEO Engine by Lantern Row <info@lanternrow.com> (https://lanternrow.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lanternrow/linkedin-pages-mcp.git"
  },
  "homepage": "https://github.com/lanternrow/linkedin-pages-mcp#readme",
  "bugs": {
    "url": "https://github.com/lanternrow/linkedin-pages-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}
