# LinkedIn Pages MCP credentials — copy to ".env" and fill in.
# ".env" is gitignored and must NEVER be committed or shared.
#
# These come from your approved LinkedIn developer app (Community Management API)
# after a Page admin completes the 3-legged OAuth consent flow.

# Member access token (3-legged OAuth). Lifetime ~60 days.
LINKEDIN_ACCESS_TOKEN=

# OAuth app credentials — needed only for automatic token refresh.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Refresh token (lifetime ~365 days, does NOT reset on refresh).
LINKEDIN_REFRESH_TOKEN=

# Optional: default organization (Company Page) numeric ID, e.g. 1234567.
# Tools accept an explicit org id too; this is just the default.
LINKEDIN_ORGANIZATION_ID=

# Optional: LinkedIn API version (YYYYMM). Defaults to the latest known-good.
# LinkedIn sunsets versions ~yearly — bump this when migrating.
LINKEDIN_VERSION=202606
